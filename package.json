{
    "name": "@kuratchi/koze",
    "version": "0.0.1",
    "description": "A thin, Cloudflare Workers-native web framework with Svelte-inspired syntax",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "koze": "dist/cli.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && bun run copy-vite-runtime",
        "copy-vite-runtime": "mkdir -p dist/vite/runtime && cp src/vite/runtime/*.js dist/vite/runtime/",
        "check": "tsc -p tsconfig.build.json --noEmit",
        "bench:router": "bun run bench/router-benchmark.ts",
        "bench:compiler": "bun run bench/compiler-benchmark.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run build"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
